+def test_c2_craftboat_nearby_water_wired():
+    """C2 (craftBoat / nearby water) is wired end-to-end: solvable goal +
+    mod_event nearby_block(water) gate under the context dimension. Its
+    intervention is NOT yet compilable -- reaching/placing a natural water body
+    is the pending in-world realization build (unlike C1's placeable furnace)."""
+    b = next(x for x in load_biases(strict_actions=False) if x["id"] == "C2")
+    assert b["action"] == "craftBoat" and b["mechanism"] == "mod_event"
+    assert b["dimension"] == "context"
+    assert b["payload"]["params"]["require"] == "nearby_block"
+    assert b["payload"]["params"]["block"] == "minecraft:water"
+    assert b["ground_truth"]["target"] == "nearby_block"
+    r = S.check_bias(b)
+    assert r["verified"] is True                       # goal (oak_boat) reachable
+    assert not (r["i_plus_compilable"] and r["i_minus_compilable"])  # realization pending
+
